# =============================================================================
# Gotify Configuration — Self-hosted Notification Server
# https://gotify.net/docs/config
# =============================================================================

# --- Server ---
# Port Gotify listens on (must match EXPOSE in Dockerfile)
PORT=8080

# Bind address (0.0.0.0 = all interfaces)
GOTIFY_SERVER_BINDADDRESS=0.0.0.0

# --- Default Admin User ---
# These are used on first run to create the admin account.
# CHANGE THESE after your first login.
GOTIFY_DEFAULTUSER_NAME=admin
GOTIFY_DEFAULTUSER_PASS=admin

# --- Database ---
# Gotify supports SQLite (built-in) or MySQL/MariaDB/PostgreSQL
# SQLite: database stored in the data volume (persistent)
GOTIFY_DATABASE_DIALECT=sqlite3
GOTIFY_DATABASE_CONNECTION=data/gotify.db

# For external databases, uncomment and configure:
# GOTIFY_DATABASE_DIALECT=mysql
# GOTIFY_DATABASE_CONNECTION=user:password@tcp(host:3306)/gotify?parseTime=true

# For Railway Postgres plugin:
# GOTIFY_DATABASE_DIALECT=postgres
# GOTIFY_DATABASE_CONNECTION=${{Postgres.DATABASE_URL}}

# --- Registration ---
# Set to false to disable public user registration
GOTIFY_REGISTRATION=false

# --- File Uploads ---
# Max upload size in MB (default: 20)
GOTIFY_UPLOADEDIMAGES_DIR=data/images
GOTIFY_FILE_SIZE=20

# --- SSL/TLS ---
# Railway handles TLS at the edge; leave these unset
# GOTIFY_SERVER_SSL_ENABLED=false
# GOTIFY_SERVER_SSL_CERTFILE=
# GOTIFY_SERVER_SSL_KEYFILE=

# --- Logging ---
# Log level: debug, info, warning, error, fatal, panic
GOTIFY_SERVER_LOG_LEVEL=info
